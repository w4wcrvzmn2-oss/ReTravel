# PostgreSQL
POSTGRES_USER=retravel
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=retravel

# Redis
REDIS_PASSWORD=change_me_redis_password

# JWT — генерировать: openssl rand -hex 64
JWT_SECRET=change_me_jwt_secret_64_chars_minimum
JWT_REFRESH_SECRET=change_me_refresh_secret_64_chars_minimum

# SMTP (для уведомлений о снижении цены)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
FROM_EMAIL=noreply@retravel.ru

# Domain (для SSL)
DOMAIN=retravel.ru

# Frontend (Vite)
VITE_API_URL=http://localhost/api
